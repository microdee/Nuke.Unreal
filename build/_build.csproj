<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <NoWarn>CS0649;CS0169</NoWarn>
    <!--<Nullable>enable</Nullable>-->
    <NukeRootDirectory>..</NukeRootDirectory>
    <NukeScriptDirectory>..</NukeScriptDirectory>
    <NukeTelemetryVersion>1</NukeTelemetryVersion>
    <LangVersion>12</LangVersion>
  </PropertyGroup>

  <!-- <ItemGroup>
    <ProjectReference Include="../../md.Nuke.Cola/md.Nuke.Cola/md.Nuke.Cola.csproj" />
  </ItemGroup> -->

  <ItemGroup>
    <PackageReference Include="Humanizer.Core" Version="2.14.1" />
    <PackageReference Include="Nuke.Common" Version="10.1.0" />
    <PackageReference Include="Scriban" Version="6.6.0" GeneratePathProperty="true" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.0.0-2.final" />
    <PackageReference Include="Towel" Version="1.0.40" />
    <PackageReference Include="md.Nuke.Cola" Version="2.4.4" />
  </ItemGroup>
  
  <ItemGroup>
    <Content Include="./Generators/Templates/**/*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
  
  <ItemGroup>
    <PackageDownload Include="GitVersion.Tool" Version="[5.12.0]" />
  </ItemGroup>

</Project>
